---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import '@fontsource-variable/bricolage-grotesque';

export interface Props {
  title?: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();
const defaultDescription =
  "Wahkonsa Lodge offers free digital art, printable coloring pages, wallpapers, and school-friendly creative ideas from Iowa.";

const { title, description = defaultDescription } = Astro.props;

const makeTitle = title
  ? title + " | " + "Wahkonsa Lodge"
  : "Wahkonsa Lodge | Digital Art, Coloring Pages, and Wallpapers";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Wahkonsa Lodge",
    url: Astro.site?.toString(),
    description: defaultDescription,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Wahkonsa Lodge",
    url: Astro.site?.toString(),
    logo: resolvedImageWithDomain,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: makeTitle,
    url: canonicalURL,
    description,
    image: resolvedImageWithDomain,
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Wahkonsa Lodge banner",
        },
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />


<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2Q5FRRB9LE"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-2Q5FRRB9LE');
</script>


  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>


  </body>
</html>
