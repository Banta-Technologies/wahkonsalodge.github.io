---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import '@fontsource-variable/bricolage-grotesque';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const defaultDescription =
  "Wahkonsa Lodge offers free printable coloring pages, wallpaper downloads, digital art, and school-friendly creative ideas.";

const {
  title,
  description = defaultDescription,
  image = "/opengraph.jpg",
  imageAlt = "Wahkonsa Lodge printable coloring pages and digital art",
  type = "website",
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  tags = [],
} = Astro.props;

const defaultImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();
const resolvedImageWithDomain = new URL(image, Astro.site).toString();

const makeTitle = title
  ? title + " | " + "Wahkonsa Lodge"
  : "Wahkonsa Lodge | Free Coloring Pages, Wallpaper, and Digital Art";

const pageSchemaType = type === "article" ? "BlogPosting" : "WebPage";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Wahkonsa Lodge",
    url: Astro.site?.toString(),
    description: defaultDescription,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Wahkonsa Lodge",
    url: Astro.site?.toString(),
    logo: defaultImageWithDomain,
  },
  {
    "@context": "https://schema.org",
    "@type": pageSchemaType,
    name: makeTitle,
    headline: makeTitle,
    url: canonicalURL,
    description,
    image: resolvedImageWithDomain,
    ...(author ? { author: { "@type": "Person", name: author } } : {}),
    ...(publishedTime ? { datePublished: publishedTime } : {}),
    ...(modifiedTime ? { dateModified: modifiedTime } : {}),
    ...(tags.length ? { keywords: tags.join(", ") } : {}),
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      robotsExtras="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
      twitter={{
        card: "summary_large_image",
        title: makeTitle,
        description,
        image: resolvedImageWithDomain,
        imageAlt,
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type,
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        optional: {
          description,
          locale: "en_US",
          siteName: "Wahkonsa Lodge",
        },
        image: {
          secureUrl: resolvedImageWithDomain,
          type: "image/jpeg",
          width: 1200,
          height: 630,
          alt: imageAlt,
        },
        ...(type === "article"
          ? {
              article: {
                publishedTime,
                modifiedTime,
                authors: author ? [author] : undefined,
                tags,
              },
            }
          : {}),
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />


<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-2Q5FRRB9LE"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-2Q5FRRB9LE');
</script>


  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>


  </body>
</html>
