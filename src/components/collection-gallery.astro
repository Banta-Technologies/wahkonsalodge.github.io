---
interface GalleryItem {
  title: string;
  category?: string;
  image: string;
  thumb: string;
}

interface Props {
  items: GalleryItem[];
  action?: string;
}

const { items, action = "View image" } = Astro.props;
---

<div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
  {
    items.map((item) => (
      <a
        href={item.image}
        target="_blank"
        rel="noopener"
        class="group rounded-lg border border-slate-200 bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        aria-label={`${action}: ${item.title}`}
      >
        <div class="aspect-[4/3] overflow-hidden rounded-md bg-slate-50">
          <img
            src={item.thumb}
            alt={`${item.title} wallpaper image`}
            loading="lazy"
            class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]"
          />
        </div>
        <p class="mt-3 truncate text-sm font-medium text-slate-700">
          {item.title}
        </p>
        {
          item.category && (
            <p class="mt-1 text-xs font-medium text-slate-500">
              {item.category}
            </p>
          )
        }
        <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 transition group-hover:border-teal-200 group-hover:bg-teal-50">
          {action}
        </p>
      </a>
    ))
  }
</div>
