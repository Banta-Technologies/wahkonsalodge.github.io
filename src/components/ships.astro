---
import CollectionGallery from "@components/collection-gallery.astro";
import RelatedCollections from "@components/related-collections.astro";
import { collectionCopy } from "../data/collections";
import { wallpaperItems } from "../data/wallpaper";

const shipItems = wallpaperItems.filter((item) => item.category === "Ships");
---

<main class="py-8">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900">
      Ships
    </h1>
    <p class="mt-3 text-lg leading-8 text-slate-600">
      {collectionCopy.ships.intro}
    </p>
  </div>

  <CollectionGallery items={shipItems} action="View ship wallpaper" />
  <RelatedCollections currentPath="/ships" />
</main>
