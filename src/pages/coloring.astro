const categories = [
  "All",
  ...Array.from(new Set(coloringPages.map((page) => page.category))).sort(),
];

function formatTitle(filename: string) {
  return filename
    .replace(/\.[^/.]+$/, "")
    .replace(/[-_]+/g, " ")
    .replace(/([a-z])([A-Z])/g, "$1 $2")
    .replace(/([a-zA-Z])(\d)/g, "$1 $2")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}
---

<Layout
  title={collectionCopy.coloring.title}
  description={collectionCopy.coloring.description}
>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Coloring Book
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          {collectionCopy.coloring.intro}
        </p>
      </div>

      <div
        class="mt-6 flex gap-2 overflow-x-auto pb-2"
        role="list"
        aria-label="Coloring page categories"
      >
        {
          categories.map((category) => (
            <button
              type="button"
              data-category-filter={category}
              class="shrink-0 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-teal-600 hover:text-teal-700 data-[active=true]:border-teal-700 data-[active=true]:bg-teal-700 data-[active=true]:text-white"
              aria-pressed={category === "All" ? "true" : "false"}
              data-active={category === "All" ? "true" : "false"}
            >
              {category}
            </button>
          ))
        }
      </div>

      <div
        id="coloring-grid"
        class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
      >
        {
          coloringPages.map(({ file, category }) => {
            const title = formatTitle(file);
            const src = `/images/coloring/${file}`;

            return (
              <a
                href={src}
                data-coloring-card
                data-category={category}
                data-image={src}
                data-title={title}
                class="group rounded-lg border border-slate-200 bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md"
                aria-label={`Open ${title}`}
              >
                <div class="aspect-[3/4] overflow-hidden rounded-md bg-slate-50">
                  <img
                    src={src}
                    alt={`${title} printable coloring page`}
                    loading="lazy"
                    class="h-full w-full object-contain transition duration-200 group-hover:scale-[1.02]"
                  />
                </div>
                <p class="mt-3 truncate text-sm font-medium text-slate-700">
                  {title}
                </p>
                <p class="mt-1 text-xs font-medium text-slate-500">
                  {category}
                </p>
                <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 transition group-hover:border-teal-200 group-hover:bg-teal-50">
                  Open printable page
                </p>
              </a>
            );
          })
        }
      </div>
      <RelatedCollections currentPath="/coloring" />
    </main>
  </Container>
</Layout>

<script>
  import { trackColoringPageOpen } from "../utils/ga4";

  const filterButtons = document.querySelectorAll("[data-category-filter]");
  const cards = document.querySelectorAll("[data-coloring-card]");

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const selectedCategory = button.getAttribute("data-category-filter");

      filterButtons.forEach((item) => {
        const isActive = item === button;
        item.setAttribute("aria-pressed", String(isActive));
        item.setAttribute("data-active", String(isActive));
      });

      cards.forEach((card) => {
        const shouldShow =
          selectedCategory === "All" ||
          card.getAttribute("data-category") === selectedCategory;

        card.classList.toggle("hidden", !shouldShow);
      });
    });
  });

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      if (!(card instanceof HTMLAnchorElement)) {
        return;
      }

      const image = card.dataset.image || card.href;
      const title = card.dataset.title;
      const category = card.dataset.category;

      trackColoringPageOpen(image, title, category);
    });
  });
</script>
