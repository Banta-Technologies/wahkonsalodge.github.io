---
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import Logos from "@components/logos.astro";
import Layout from "@layouts/Layout.astro";
import { collectionCopy } from "../data/collections";

const homeDescription =
  "Explore free Wahkonsa Lodge coloring pages, wallpapers, Midwest lake life, nature, fishing, birds, pollinators, classic cars, motorcycles, and family-friendly digital art.";
---

<Layout
  description={homeDescription}
>
  <Container>
    <Hero />
    <section class="mx-auto max-w-4xl pb-12" aria-labelledby="home-collections-title">
      <h1
        id="home-collections-title"
        class="text-4xl font-bold tracking-tight text-slate-900"
      >
        Free Coloring Pages, Wallpaper, and Digital Art
      </h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Wahkonsa Lodge is a family-friendly creative library inspired by Midwest
        lake life, old river paths, woodland trails, fishing docks, birds,
        pollinators, classic cars, motorcycles, and quiet moments outdoors.
        Explore free printable coloring pages, phone and desktop wallpapers, and
        rustic digital art collections made for kids, families, classrooms, and
        anyone who enjoys peaceful lodge-style imagery.
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <a
          href="/coloring"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">
            {collectionCopy.coloring.title}
          </h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Birds, flowers, wildlife, nature scenes, dinosaurs, food, and silly
            printable pages for kids, families, and classrooms.
          </p>
        </a>
        <a
          href="/wallpaper"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">
            {collectionCopy.wallpaper.title}
          </h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Free backgrounds for phones, tablets, and desktops with shorelines,
            woodland trails, birds, pollinators, cars, and motorcycles.
          </p>
        </a>
        <a
          href="/request-coloring-page"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">
            Request a Coloring Page
          </h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Suggest a school-friendly coloring page idea for a future Wahkonsa
            Lodge printable.
          </p>
        </a>
      </div>
    </section>
    <!-- <Features />
    <Logos />
    <Cta /> -->
  </Container>
</Layout>
