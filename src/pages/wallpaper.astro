---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import { wallpaperItems } from "../data/wallpaper";

const categories = [
  "All",
  ...Array.from(new Set(wallpaperItems.map((item) => item.category))).sort(),
];
---

<Layout
  title="Free Wallpaper Downloads"
  description="Download free Wahkonsa Lodge wallpaper images including birds, lake scenes, critters, ships, classic cars, anime, and random digital art."
>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Wallpaper
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          Browse Wahkonsa Lodge wallpaper images by category.
        </p>
      </div>

      <div
        class="mt-6 flex gap-2 overflow-x-auto pb-2"
        role="list"
        aria-label="Wallpaper categories"
      >
        {
          categories.map((category) => (
            <button
              type="button"
              data-wallpaper-filter={category}
              class="shrink-0 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-teal-600 hover:text-teal-700 data-[active=true]:border-teal-700 data-[active=true]:bg-teal-700 data-[active=true]:text-white"
              aria-pressed={category === "All" ? "true" : "false"}
              data-active={category === "All" ? "true" : "false"}
            >
              {category}
            </button>
          ))
        }
      </div>

      <div
        id="wallpaper-grid"
        class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
      >
        {
          wallpaperItems.map((item) => (
            <button
              type="button"
              data-wallpaper-card
              data-category={item.category}
              data-image={item.image}
              data-title={item.title}
              class="group rounded-lg border border-slate-200 bg-white p-3 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
              aria-label={`Preview ${item.title}`}
            >
              <div class="aspect-[4/3] overflow-hidden rounded-md bg-slate-50">
                <img
                  src={item.thumb}
                  alt={item.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]"
                />
              </div>
              <p class="mt-3 truncate text-sm font-medium text-slate-700">
                {item.title}
              </p>
              <p class="mt-1 text-xs font-medium text-slate-500">
                {item.category}
              </p>
              <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 transition group-hover:border-teal-200 group-hover:bg-teal-50">
                View wallpaper
              </p>
            </button>
          ))
        }
      </div>
    </main>
  </Container>

  <div
    id="wallpaper-preview"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/80 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="wallpaper-preview-title"
  >
    <div class="flex max-h-full w-full max-w-5xl flex-col rounded-lg bg-white shadow-2xl">
      <div
        class="flex items-center justify-between gap-4 border-b border-slate-200 px-4 py-3 sm:px-5"
      >
        <h2
          id="wallpaper-preview-title"
          class="min-w-0 truncate text-base font-semibold text-slate-900"
        >
          Wallpaper preview
        </h2>
        <button
          type="button"
          data-wallpaper-close
          class="rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          Close
        </button>
      </div>

      <div class="min-h-0 flex-1 bg-slate-100 p-3 sm:p-5">
        <img
          id="wallpaper-preview-image"
          src=""
          alt=""
          class="mx-auto max-h-[72vh] w-full object-contain"
        />
      </div>

      <div class="flex flex-col gap-3 border-t border-slate-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5">
        <p class="text-sm text-slate-600">
          Download only starts when you choose the button.
        </p>
        <a
          id="wallpaper-download"
          href="#"
          download
          class="rounded-md bg-teal-700 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-teal-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          Download wallpaper
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { trackWallpaperDownload, trackWallpaperView } from "../utils/ga4";

  const filterButtons = document.querySelectorAll("[data-wallpaper-filter]");
  const cards = document.querySelectorAll("[data-wallpaper-card]");
  const preview = document.querySelector("#wallpaper-preview");
  const previewImage = document.querySelector("#wallpaper-preview-image");
  const previewTitle = document.querySelector("#wallpaper-preview-title");
  const downloadLink = document.querySelector("#wallpaper-download");
  const closeButton = document.querySelector("[data-wallpaper-close]");

  let lastFocusedElement = null;
  let selectedWallpaper = null;

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const selectedCategory = button.getAttribute("data-wallpaper-filter");

      filterButtons.forEach((item) => {
        const isActive = item === button;
        item.setAttribute("aria-pressed", String(isActive));
        item.setAttribute("data-active", String(isActive));
      });

      cards.forEach((card) => {
        const shouldShow =
          selectedCategory === "All" ||
          card.getAttribute("data-category") === selectedCategory;

        card.classList.toggle("hidden", !shouldShow);
      });
    });
  });

  const closePreview = () => {
    if (
      !(preview instanceof HTMLElement) ||
      !(previewImage instanceof HTMLImageElement)
    ) {
      return;
    }

    preview.classList.add("hidden");
    preview.classList.remove("flex");
    previewImage.removeAttribute("src");
    previewImage.alt = "";
    selectedWallpaper = null;
    document.body.classList.remove("overflow-hidden");

    if (lastFocusedElement instanceof HTMLElement) {
      lastFocusedElement.focus();
    }
  };

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      if (
        !(card instanceof HTMLElement) ||
        !(preview instanceof HTMLElement) ||
        !(previewImage instanceof HTMLImageElement) ||
        !(previewTitle instanceof HTMLElement) ||
        !(downloadLink instanceof HTMLAnchorElement) ||
        !(closeButton instanceof HTMLButtonElement)
      ) {
        return;
      }

      const image = card.dataset.image;
      const title = card.dataset.title;
      const category = card.dataset.category;

      if (!image || !title || !category) {
        return;
      }

      selectedWallpaper = { image, title, category };
      lastFocusedElement = document.activeElement;
      previewImage.src = image;
      previewImage.alt = title;
      previewTitle.textContent = title;
      downloadLink.href = image;
      downloadLink.setAttribute("download", image.split("/").pop() || "");

      preview.classList.remove("hidden");
      preview.classList.add("flex");
      document.body.classList.add("overflow-hidden");
      closeButton.focus();

      trackWallpaperView(image, title, category);
    });
  });

  downloadLink?.addEventListener("click", () => {
    if (!selectedWallpaper) {
      return;
    }

    trackWallpaperDownload(
      selectedWallpaper.image,
      selectedWallpaper.title,
      selectedWallpaper.category,
    );
  });

  closeButton?.addEventListener("click", closePreview);

  preview?.addEventListener("click", (event) => {
    if (event.target === preview) {
      closePreview();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closePreview();
    }
  });
</script>
