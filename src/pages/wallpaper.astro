---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import { wallpaperItems } from "../data/wallpaper";

const categories = [
  "All",
  ...Array.from(new Set(wallpaperItems.map((item) => item.category))).sort(),
];
---

<Layout title="Wallpaper">
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Wallpaper
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          Browse Wahkonsa Lodge wallpaper images by category.
        </p>
      </div>

      <div
        class="mt-6 flex gap-2 overflow-x-auto pb-2"
        role="list"
        aria-label="Wallpaper categories"
      >
        {
          categories.map((category) => (
            <button
              type="button"
              data-wallpaper-filter={category}
              class="shrink-0 rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-teal-600 hover:text-teal-700 data-[active=true]:border-teal-700 data-[active=true]:bg-teal-700 data-[active=true]:text-white"
              aria-pressed={category === "All" ? "true" : "false"}
              data-active={category === "All" ? "true" : "false"}
            >
              {category}
            </button>
          ))
        }
      </div>

      <div
        id="wallpaper-grid"
        class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
      >
        {
          wallpaperItems.map((item) => (
            <a
              href={item.image}
              download
              data-wallpaper-card
              data-category={item.category}
              class="group rounded-lg border border-slate-200 bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md"
              aria-label={`Download ${item.title}`}
            >
              <div class="aspect-[4/3] overflow-hidden rounded-md bg-slate-50">
                <img
                  src={item.thumb}
                  alt={item.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]"
                />
              </div>
              <p class="mt-3 truncate text-sm font-medium text-slate-700">
                {item.title}
              </p>
              <p class="mt-1 text-xs font-medium text-slate-500">
                {item.category}
              </p>
              <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 transition group-hover:border-teal-200 group-hover:bg-teal-50">
                Download wallpaper
              </p>
            </a>
          ))
        }
      </div>
    </main>
  </Container>
</Layout>

<script>
  const filterButtons = document.querySelectorAll("[data-wallpaper-filter]");
  const cards = document.querySelectorAll("[data-wallpaper-card]");

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const selectedCategory = button.getAttribute("data-wallpaper-filter");

      filterButtons.forEach((item) => {
        const isActive = item === button;
        item.setAttribute("aria-pressed", String(isActive));
        item.setAttribute("data-active", String(isActive));
      });

      cards.forEach((card) => {
        const shouldShow =
          selectedCategory === "All" ||
          card.getAttribute("data-category") === selectedCategory;

        card.classList.toggle("hidden", !shouldShow);
      });
    });
  });
</script>
