---
import CollectionGallery from "@components/collection-gallery.astro";
import Container from "@components/container.astro";
import RelatedCollections from "@components/related-collections.astro";
import Layout from "@layouts/Layout.astro";
import { noniAndPapaItems } from "../data/noni-and-papa";

const title = "Noni and Papa";
const description =
  "Browse Noni and Papa images from Wahkonsa Lodge, with thumbnail previews that open full-size images.";
---

<Layout title={title} description={description}>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          {title}
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          A family gallery space for Noni and Papa images. The grid is ready for
          thumbnail previews that open full-size originals.
        </p>
      </div>

      {
        noniAndPapaItems.length > 0 ? (
          <CollectionGallery
            items={noniAndPapaItems}
            action="View Noni and Papa image"
          />
        ) : (
          <section class="mt-6 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">
              Gallery coming soon
            </h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Add full-size images to <code>public/images/noni-and-papa/</code>,
              add matching thumbnails to{" "}
              <code>public/images/noni-and-papa/thumbs/</code>, then list them
              in <code>src/data/noni-and-papa.ts</code>.
            </p>
          </section>
        )
      }

      <RelatedCollections currentPath="/noni-and-papa" />
    </main>
  </Container>
</Layout>

