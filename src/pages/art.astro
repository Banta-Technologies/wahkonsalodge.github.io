---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import CollectionGallery from "@components/collection-gallery.astro";
import RelatedCollections from "@components/related-collections.astro";
import { collectionCopy } from "../data/collections";
import { wallpaperItems } from "../data/wallpaper";

const featuredItems = wallpaperItems.filter((item) =>
  ["Lake Scenes", "Pollinators", "Random"].includes(item.category)
);
---

<Layout
  title={collectionCopy.art.title}
  description={collectionCopy.art.description}
>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Digital Art Gallery
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          {collectionCopy.art.intro}
        </p>
      </div>

      <CollectionGallery items={featuredItems} action="View digital art" />
      <RelatedCollections currentPath="/art" />
    </main>
  </Container>
</Layout>
