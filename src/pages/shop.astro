---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout title="Shop">
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Shop Wahkonsa Lodge
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          Browse Wahkonsa Lodge art and merch on Redbubble.
        </p>
      </div>

      <div class="mt-8">
        <script
          type="text/javascript"
          src="https://www.redbubble.com/assets/external_portfolio.js"
        ></script>
        <script
          id="rb-xzfcxvzx"
          type="text/javascript"
          is:inline
        >
          new RBExternalPortfolio('www.redbubble.com', 'wahkonsalodge', 50, 1).renderIframe();
        </script>
      </div>
    </main>
  </Container>
</Layout>
