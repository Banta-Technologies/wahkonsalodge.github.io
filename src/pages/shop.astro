---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";

const redbubbleShopUrl = "https://www.redbubble.com/people/wahkonsalodge/shop";
---

<Layout
  title="Shop Wahkonsa Lodge"
  description="Shop Wahkonsa Lodge art and merch on Redbubble and support new printable coloring pages, wallpaper downloads, and digital art."
>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Shop Wahkonsa Lodge
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          Browse Wahkonsa Lodge art and merch on Redbubble, including prints,
          stickers, mugs, apparel, and gifts.
        </p>
        <div class="mt-6">
          <a
            href={redbubbleShopUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex rounded-md bg-teal-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-teal-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
          >
            Open the Redbubble shop
          </a>
        </div>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a
          href={`${redbubbleShopUrl}?iaCode=u-prints`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">Prints</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Wall art and art prints featuring Wahkonsa Lodge designs.
          </p>
        </a>
        <a
          href={`${redbubbleShopUrl}?iaCode=u-stickers`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">Stickers</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Sticker designs for notebooks, water bottles, laptops, and gifts.
          </p>
        </a>
        <a
          href={`${redbubbleShopUrl}?iaCode=u-clothing`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-slate-200 bg-white p-5 transition hover:border-teal-200 hover:bg-teal-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
        >
          <h2 class="text-lg font-semibold text-slate-900">Apparel</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Shirts, hoodies, and other wearable Wahkonsa Lodge art.
          </p>
        </a>
      </div>
    </main>
  </Container>
</Layout>
