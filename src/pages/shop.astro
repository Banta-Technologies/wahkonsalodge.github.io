---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";

const amazonBeachLifeShirtUrl = "https://www.amazon.com/dp/B0F6M1VJGS";
const amazonMacawTumblerUrl =
  "https://www.amazon.com/Green-Portrait-Stainless-Insulated-Tumbler/dp/B0F4RSPYVH";
const amazonMacawBeachLifeShirtUrl = "https://www.amazon.com/dp/B0F6KT764M";
const amazonChoreTimeShirtUrl = "https://www.amazon.com/dp/B0H68CWXPH";
const amazonFeaturedProductUrl = "https://www.amazon.com/dp/B0H6C2SPH1";
const amazonEasternBluebirdsTumblerUrl = "https://www.amazon.com/dp/B0H6GC2WDV";

const featuredProducts = [
  {
    title: "Beach Life Premium Tri-blend T-Shirt",
    text: "A soft Wahkonsa Lodge shirt with a small front breast design and a larger Beach Life graphic on the back.",
    href: amazonBeachLifeShirtUrl,
    image: "/images/shop/beach-life-shirt-front-back-amazon.png",
    source: "Amazon",
  },
  {
    title: "Red and Green Macaw Portrait Stainless Steel Insulated Tumbler",
    text: "A bright macaw tumbler available through Amazon.",
    href: amazonMacawTumblerUrl,
    image: "/images/shop/macaw-tumbler-amazon.jpg",
    source: "Amazon",
  },
  {
    title: "Red and Green Macaw Portrait Beach Life Premium Tri-blend T-Shirt",
    text: "A soft macaw shirt with a small front breast design and a larger Beach Life graphic on the back.",
    href: amazonMacawBeachLifeShirtUrl,
    image: "/images/shop/macaw-beach-life-shirt-front-back-amazon.png",
    source: "Amazon",
  },
  {
    title: "Chore Time Fiddle-Fartin’ Country Humor T-Shirt",
    text: "A country humor shirt available through Amazon.",
    href: amazonChoreTimeShirtUrl,
    image: "/images/shop/chore-time-fiddle-fartin-shirt-amazon.png",
    source: "Amazon",
  },
  {
    title: "Red-Winged Blackbird on Cattails Stainless Steel Insulated Tumbler",
    text: "Detailed red-winged blackbird artwork featuring vivid red and yellow shoulder markings, glossy black feathers, and natural cattails.",
    href: amazonFeaturedProductUrl,
    image: "/images/shop/red-winged-blackbird-cattails-tumbler-amazon.png",
    source: "Amazon",
  },
  {
    title: "Eastern Bluebirds Stainless Steel Insulated Tumbler",
    text: "Detailed Eastern bluebird artwork with vivid blue wings, warm orange breasts, spring blossoms, a weathered wooden post, and natural grasses.",
    href: amazonEasternBluebirdsTumblerUrl,
    image: "/images/shop/eastern-bluebirds-tumbler-amazon.png",
    source: "Amazon",
  },
];
---

<Layout
  title="Shop Wahkonsa Lodge"
  description="Shop featured Wahkonsa Lodge products and support new printable coloring pages, wallpaper downloads, and digital art."
>
  <Container>
    <main class="py-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          Shop Wahkonsa Lodge
        </h1>
        <p class="mt-3 text-lg leading-8 text-slate-600">
          Browse featured Wahkonsa Lodge products, gifts, apparel, and home
          goods.
        </p>
      </div>

      <section class="mt-10" aria-labelledby="featured-products-title">
        <h2
          id="featured-products-title"
          class="text-2xl font-bold tracking-tight text-slate-900"
        >
          Featured Products
        </h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            featuredProducts.map((product) => (
              <a
                href={product.href}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="group rounded-lg border border-slate-200 bg-white p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-teal-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-600 focus-visible:ring-offset-2"
              >
                <div class="aspect-[4/3] overflow-hidden rounded-md bg-slate-50">
                  <img
                    src={product.image}
                    alt={product.title}
                    loading="lazy"
                    class="h-full w-full object-contain transition duration-200 group-hover:scale-[1.02]"
                  />
                </div>
                <h3 class="mt-3 text-base font-semibold text-slate-900">
                  {product.title}
                </h3>
                <p class="mt-1 text-sm leading-6 text-slate-600">
                  {product.text}
                </p>
                <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-center text-xs font-semibold text-teal-700 transition group-hover:border-teal-200 group-hover:bg-teal-50">
                  View on {product.source}
                </p>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </Container>
</Layout>
